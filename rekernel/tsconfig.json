{
  "compilerOptions": {
    "target":              "ESNext",
    "module":              "ESNext",
    "moduleResolution":    "bundler",
    "outDir":              "../rekernel-dist",
    "rootDir":             ".",
    "declaration":         true,
    "declarationDir":      "../rekernel-dist",
    "strict":              true,
    "esModuleInterop":     true,
    "skipLibCheck":        true,
    "resolveJsonModule":   true,
    "noEmitOnError":       false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../rekernel-dist"
  ]
}
